# PostgreSQL 連線範例格式
# 請在 Zeabur Dashboard 中建立 PostgreSQL 資源後，複製連線 URL 貼到這裡

# 本地開發使用 PostgreSQL（感應 .env）
DATABASE_URL="postgresql://"

# 在 Zeabur 上，應該是類似這樣：
# DATABASE_URL="postgresql://avnadmin:你的密碼@host-1.zai-gateway.com:5432/zeabur?schema=public"

# JWT Secret
JWT_SECRET="pearl-ta-dev-secret-key-change-in-production"