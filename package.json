{
  "name": "pearl-tea-pos",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "node tests/simple-test.js",
    "test:full": "npm run test && npm run test:api",
    "test:network": "ts-node tests/network.ts",
    "test:database": "ts-node tests/database.ts",
    "test:api": "ts-node tests/api.ts",
    "db:push": "npx prisma db push",
    "db:migrate": "npx prisma migrate dev --skip-generate",
    "db:migrate:prod": "npx prisma migrate deploy",
    "db:reset": "npx prisma migrate reset --force --skip-generate",
    "db:seed": "prisma db seed",
    "db:seed:admin": "node prisma/seed-admin.js",
    "db:seed:products": "node prisma/seed-products.js",
    "db:seed:all": "node prisma/seed-admin.js && node prisma/seed-products.js",
    "db:studio": "npx prisma studio",
    "db:generate": "npx prisma generate",
    "db:check": "npx prisma validate"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^6.19.0",
    "@prisma/client": "^7.8.0",
    "autoprefixer": "^10.5.0",
    "bcryptjs": "^3.0.3",
    "jsonwebtoken": "^9.0.2",
    "next": "14.2.0",
    "pg": "^8.21.0",
    "postcss": "^8.5.15",
    "prisma": "^7.8.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "tailwindcss": "3.4.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.4.0",
    "eslint-config-next": "^16.2.6",
    "ts-node": "^10.9.2",
    "typescript": "6.0.3"
  }
}
